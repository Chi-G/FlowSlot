<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /flowslot/

    # 1. First, try to serve existing assets from the public folder
    RewriteCond %{DOCUMENT_ROOT}/flowslot/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # 2. Redirect everything else (API, routes) to our public index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>
